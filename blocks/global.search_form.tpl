<!-- BEGIN: main -->
<form role="search" action="{THEME_SEARCH_URL}" method="get" class="w-full shrink-0 m-0">
  <div class="flex items-center bg-[#f4f5f7] rounded-full focus-within:bg-white focus-within:shadow-md border border-transparent transition-all h-16 sm:h-[72px] group">
    <input type="text" name="q" value="{KEYWORD}" placeholder="Tìm kiếm thông báo, ngành học..." class="flex-1 min-w-0 bg-transparent border-none px-6 sm:px-8 text-base sm:text-lg text-slate-700 placeholder-[#8b9bb4] focus:outline-none focus:ring-0 w-full h-full" required />
    <button type="submit" aria-label="{LANG.search}" class="h-full w-16 sm:w-[72px] bg-transparent text-[#6b7b94] hover:text-[#1a428a] transition-colors focus:outline-none flex items-center justify-center border-none cursor-pointer m-0 shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" class="shrink-0" style="display:block;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </button>
  </div>
</form>
<!-- END: main -->
