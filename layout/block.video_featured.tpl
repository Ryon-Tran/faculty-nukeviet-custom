<!-- BEGIN: main -->
<div class="video-featured-wrapper">
    <h3 class="section-title">| Video nổi bật</h3>
    <!-- BEGIN: loop -->
    <div class="video-featured-main">
        <a href="{ROW.link}" title="{ROW.title}" class="play-btn-overlay">
            <img src="{ROW.thumb}" alt="{ROW.title}" class="img-responsive">
            <i class="fa fa-play-circle play-icon"></i>
        </a>
    </div>
    <!-- END: loop -->
    <div class="video-featured-list">
        <!-- BEGIN: other -->
        <div class="video-small-item">
            <a href="{OTHER.link}" title="{OTHER.title}">
                <img src="{OTHER.thumb}" alt="{OTHER.title}" class="img-responsive">
                <i class="fa fa-play-circle play-icon-small"></i>
            </a>
        </div>
        <!-- END: other -->
    </div>
    <div class="text-right">
        <a href="#" class="view-more">Xem thêm</a>
    </div>
</div>
<!-- END: main -->
